{% raw %}
groups:
  - name: tracing_alerts
    rules:
      # US-T02: Alert when P95 latency exceeds 1 second
      - alert: HighP95Latency
        expr: histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{job="app-spring-actuator"}[5m])) by (le)) * 1000 > 1000
        for: 2m
        labels:
          severity: warning
        annotations:
          summary: "P95 request latency exceeds 1s"
          description: "The 95th percentile latency for Spring Boot requests has been above 1000ms for 2 minutes."

      # US-T02: Alternative using Kong metrics
      - alert: HighKongP95Latency
        expr: histogram_quantile(0.95, sum(rate(kong_request_latency_ms_bucket[5m])) by (le)) > 1000
        for: 2m
        labels:
          severity: warning
        annotations:
          summary: "P95 Kong request latency exceeds 1s"
          description: "The 95th percentile end-to-end latency measured at Kong has been above 1000ms for 2 minutes."

      # US-T04: Alert when OTel Collector drops more than 5% of spans
      - alert: OTelCollectorHighSpanDropRate
        expr: >
          (
            sum(rate(otelcol_processor_dropped_spans_total[5m]))
            /
            clamp_min(sum(rate(otelcol_receiver_accepted_spans_total[5m])), 1)
          ) > 0.05
        for: 2m
        labels:
          severity: critical
        annotations:
          summary: "OTel Collector dropping >5% of spans"
          description: "The OTel Collector is dropping {{ $value | humanizePercentage }} of received spans."

      # US-T04: Alert when OTel Collector is down
      - alert: OTelCollectorDown
        expr: up{job="otel-collector"} == 0
        for: 1m
        labels:
          severity: critical
        annotations:
          summary: "OTel Collector is down"
          description: "The OTel Collector instance has been unreachable for 1 minute."

  - name: infrastructure_alerts
    rules:
      # Disk usage exceeds 85%
      - alert: HighDiskUsage
        expr: (1 - node_filesystem_avail_bytes{mountpoint="/",fstype!=""} / node_filesystem_size_bytes{mountpoint="/",fstype!=""}) * 100 > 85
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "Disk usage above 85% on {{ $labels.instance }}"
          description: "Root filesystem on {{ $labels.instance }} is at {{ $value | humanize }}% usage."

      # Disk usage exceeds 95% (critical)
      - alert: CriticalDiskUsage
        expr: (1 - node_filesystem_avail_bytes{mountpoint="/",fstype!=""} / node_filesystem_size_bytes{mountpoint="/",fstype!=""}) * 100 > 95
        for: 2m
        labels:
          severity: critical
        annotations:
          summary: "Disk usage above 95% on {{ $labels.instance }}"
          description: "Root filesystem on {{ $labels.instance }} is at {{ $value | humanize }}% usage. Immediate action required."

      # CPU usage sustained above 85%
      - alert: HighCpuUsage
        expr: 100 - (avg by(instance) (rate(node_cpu_seconds_total{mode="idle"}[5m])) * 100) > 85
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "High CPU usage on {{ $labels.instance }}"
          description: "CPU usage on {{ $labels.instance }} has been above 85% for 5 minutes (current: {{ $value | humanize }}%)."

      # CPU usage sustained above 95% (critical)
      - alert: CriticalCpuUsage
        expr: 100 - (avg by(instance) (rate(node_cpu_seconds_total{mode="idle"}[5m])) * 100) > 95
        for: 2m
        labels:
          severity: critical
        annotations:
          summary: "Critical CPU usage on {{ $labels.instance }}"
          description: "CPU usage on {{ $labels.instance }} has been above 95% for 2 minutes (current: {{ $value | humanize }}%)."

      # Memory usage exceeds 85%
      - alert: HighMemoryUsage
        expr: (1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100 > 85
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "High memory usage on {{ $labels.instance }}"
          description: "Memory usage on {{ $labels.instance }} is at {{ $value | humanize }}%."

      # Memory usage exceeds 95% (critical)
      - alert: CriticalMemoryUsage
        expr: (1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100 > 95
        for: 2m
        labels:
          severity: critical
        annotations:
          summary: "Critical memory usage on {{ $labels.instance }}"
          description: "Memory usage on {{ $labels.instance }} is at {{ $value | humanize }}%. OOM risk."

      # Teammate integration: Medium CPU usage (80% for 1m)
      - alert: MediumCpuUsage
        expr: 100 - (avg by(instance) (rate(node_cpu_seconds_total{mode="idle"}[1m])) * 100) > 80
        for: 1m
        labels:
          severity: warning
        annotations:
          summary: "Medium CPU usage on {{ $labels.instance }}"
          description: "CPU usage on {{ $labels.instance }} has been above 80% for 1 minute (current: {{ $value | humanize }}%)."

      # Teammate integration: Medium memory usage (80% for 1m)
      - alert: MediumMemoryUsage
        expr: (1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100 > 80
        for: 1m
        labels:
          severity: warning
        annotations:
          summary: "Medium memory usage on {{ $labels.instance }}"
          description: "Memory usage on {{ $labels.instance }} is above 80% for 1 minute (current: {{ $value | humanize }}%)."

      # Any monitored target is down
      - alert: TargetDown
        expr: up == 0
        for: 2m
        labels:
          severity: critical
        annotations:
          summary: "Target {{ $labels.job }} down on {{ $labels.instance }}"
          description: "Prometheus target {{ $labels.job }} on {{ $labels.instance }} has been unreachable for 2 minutes."

      # Disk will fill within 24 hours (predictive)
      - alert: DiskFillingUp
        expr: predict_linear(node_filesystem_avail_bytes{mountpoint="/",fstype!=""}[6h], 24*3600) < 0
        for: 30m
        labels:
          severity: warning
        annotations:
          summary: "Disk predicted to fill within 24h on {{ $labels.instance }}"
          description: "Based on the last 6 hours of data, the root filesystem on {{ $labels.instance }} is predicted to run out of space within 24 hours."
  - name: log_alerts
    rules:
      # Alert when Loki disk usage is high (monitoring VM root filesystem)
      - alert: LokiHighDiskUsage
        expr: (1 - node_filesystem_avail_bytes{mountpoint="/",fstype!="",job="mon-node-exporter"} / node_filesystem_size_bytes{mountpoint="/",fstype!="",job="mon-node-exporter"}) * 100 > 85
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "High disk usage on monitoring VM (Loki storage)"
          description: "Root filesystem on monitoring VM (running Loki) is at {{ $value | humanize }}% usage."

      # Critical disk usage alert for Loki storage
      - alert: LokiCriticalDiskUsage
        expr: (1 - node_filesystem_avail_bytes{mountpoint="/",fstype!="",job="mon-node-exporter"} / node_filesystem_size_bytes{mountpoint="/",fstype!="",job="mon-node-exporter"}) * 100 > 95
        for: 2m
        labels:
          severity: critical
        annotations:
          summary: "Critical disk usage on monitoring VM (Loki storage)"
          description: "Root filesystem on monitoring VM (running Loki) is at {{ $value | humanize }}% usage. Immediate action required."

      # Alert when log ingestion rate is abnormally low (possible pipeline failure)
      # Metric name may need adjustment based on actual Loki metrics exposed
      # Verify metric exists: loki_distributor_bytes_received_total (or loki_distributor_received_bytes_total)
      # Integration tests verify Loki metrics availability; adjust threshold as needed.
      # Threshold: 1024 bytes/sec (1 KB/sec). Adjust based on baseline ingestion.
      - alert: LokiIngestionRateLow
        expr: rate(loki_distributor_bytes_received_total[5m]) < 1024
        for: 10m
        labels:
          severity: warning
        annotations:
          summary: "Log ingestion rate low on {{ $labels.instance }}"
          description: "Loki log ingestion rate has been below 1 KB/sec for 10 minutes (current: {{ $value | humanize }} bytes/sec). Check Promtail and log sources."

      # Optional: Alert on high Loki request error rate (uncomment after verifying metric exists)
      # - alert: LokiHighErrorRate
      #   expr: rate(loki_request_duration_seconds_count{code=~"5.."}[5m]) / rate(loki_request_duration_seconds_count[5m]) > 0.05
      #   for: 5m
      #   labels:
      #     severity: warning
      #   annotations:
      #     summary: "High error rate on Loki API"
      #     description: "Loki HTTP error rate exceeds 5% (current: {{ $value | humanizePercentage }}). Check Loki logs."

      # Predictive alert for Loki disk filling
      - alert: LokiDiskFillingUp
        expr: predict_linear(node_filesystem_avail_bytes{mountpoint="/",fstype!="",job="mon-node-exporter"}[6h], 24*3600) < 0
        for: 30m
        labels:
          severity: warning
        annotations:
          summary: "Loki storage disk predicted to fill within 24h"
          description: "Based on the last 6 hours of data, the root filesystem on monitoring VM (Loki storage) is predicted to run out of space within 24 hours."
{% endraw %}
