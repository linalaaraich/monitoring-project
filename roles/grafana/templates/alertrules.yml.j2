apiVersion: 1

{# K8s migration: When k3s_sd_enabled is true, use pod-based selectors instead of VM job labels. #}
{# #}
{# Spring Boot selector (k3s): the Prometheus kubernetes_sd scrape attaches `container` but NOT `app` #}
{# as a label (kong-kong is the only pod with `app=...`). So `app="spring-boot"` matched nothing in #}
{# practice. The `container="spring-boot"` label is stable across restarts/re-deploys. We also exclude #}
{# /actuator URIs because the app scraping itself inflates request counts with sub-ms spans that pull #}
{# the p95 down and mask real user-facing latency. #}
{# #}
{# OTel selector (k3s): same reason — pods don't get `app=`. `container="otel-collector"` targets the #}
{# in-cluster collector (the one Spring Boot actually exports to). The VM-mode `job="otel-collector"` #}
{# label still exists for the monitoring-VM-local collector, but that one is covered by TargetDown. #}
{% if k3s_sd_enabled | default(false) %}
{% set spring_selector = 'container="spring-boot",uri!~"/actuator.*"' %}
{% set otel_selector = 'container="otel-collector"' %}
{% else %}
{% set spring_selector = 'job="app-spring-actuator"' %}
{% set otel_selector = 'job="otel-collector"' %}
{% endif %}
{% set mon_node_selector = 'job="mon-node-exporter"' %}

groups:
  - orgId: 1
    name: tracing_alerts
    folder: Provisioned Alerts
    interval: 60s
    rules:
      # ADAPTIVE THRESHOLD — Epic 5 US-5.4 (2026-04-27).
      # Rule fires when current p95 exceeds same-hour baseline (7d ago,
      # ±1h window) by more than 3 standard deviations, OR exceeds the
      # 1000 ms static floor when no baseline history is available.
      # See decisions-log.html#d17 for the philosophy + tradeoffs.
      - uid: high-p95-latency
        title: HighP95Latency
        condition: C
        data:
          - refId: A
            datasourceUid: prometheus
            model:
              expr: |
                (histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{{ "{" }}{{ spring_selector }}{{ "}" }}[5m])) by (le)) * 1000)
                -
                (
                  avg_over_time((histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{{ "{" }}{{ spring_selector }}{{ "}" }}[5m])) by (le)) * 1000)[1h:1m] offset 7d)
                  + 3 * stddev_over_time((histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{{ "{" }}{{ spring_selector }}{{ "}" }}[5m])) by (le)) * 1000)[1h:1m] offset 7d)
                  or vector(1000)
                )
              instant: false
              range: true
              intervalMs: 15000
            relativeTimeRange:
              from: 600
              to: 0
          - refId: B
            datasourceUid: __expr__
            model:
              type: reduce
              expression: A
              reducer: last
          - refId: C
            datasourceUid: __expr__
            model:
              type: threshold
              expression: B
              conditions:
                - evaluator:
                    type: gt
                    params: [0]
        noDataState: OK
        execErrState: Error
        for: 2m
        labels:
          severity: warning
          service: spring-boot
          signal: metric
          component: api
          timeframe: 10m
          adaptive_threshold: "true"
        annotations:
          expr: 'histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{{ "{" }}{{ spring_selector }}{{ "}" }}[5m])) by (le)) * 1000'
          summary: "P95 request latency above adaptive baseline"
          description: "Spring Boot p95 latency exceeds the same-hour 7-day baseline by more than 3σ, or 1000ms if no baseline history is available. Adaptive threshold reduces false positives during off-hours and traffic-driven spikes."

      # ADAPTIVE THRESHOLD — Epic 5 US-5.4 (2026-04-27).
      # Mirror of HighP95Latency but on the kong gateway-layer histogram.
      - uid: high-kong-p95-latency
        title: HighKongP95Latency
        condition: C
        data:
          - refId: A
            datasourceUid: prometheus
            model:
              expr: |
                histogram_quantile(0.95, sum(rate(kong_request_latency_ms_bucket[5m])) by (le))
                -
                (
                  avg_over_time(histogram_quantile(0.95, sum(rate(kong_request_latency_ms_bucket[5m])) by (le))[1h:1m] offset 7d)
                  + 3 * stddev_over_time(histogram_quantile(0.95, sum(rate(kong_request_latency_ms_bucket[5m])) by (le))[1h:1m] offset 7d)
                  or vector(1000)
                )
              instant: false
              range: true
              intervalMs: 15000
            relativeTimeRange:
              from: 600
              to: 0
          - refId: B
            datasourceUid: __expr__
            model:
              type: reduce
              expression: A
              reducer: last
          - refId: C
            datasourceUid: __expr__
            model:
              type: threshold
              expression: B
              conditions:
                - evaluator:
                    type: gt
                    params: [0]
        noDataState: OK
        execErrState: Error
        for: 2m
        labels:
          severity: warning
          service: kong
          signal: metric
          component: gateway
          timeframe: 10m
          adaptive_threshold: "true"
        annotations:
          expr: 'histogram_quantile(0.95, sum(rate(kong_request_latency_ms_bucket[5m])) by (le))'
          summary: "P95 Kong latency above adaptive baseline"
          description: "Kong p95 end-to-end latency exceeds the same-hour 7-day baseline by more than 3σ, or 1000ms if no baseline history is available."

      - uid: otel-collector-high-span-drop-rate
        title: OTelCollectorHighSpanDropRate
        condition: C
        data:
          - refId: A
            datasourceUid: prometheus
            model:
              expr: '(sum(rate(otelcol_processor_dropped_spans_total[5m])) / clamp_min(sum(rate(otelcol_receiver_accepted_spans_total[5m])), 1))'
              instant: false
              range: true
              intervalMs: 15000
            relativeTimeRange:
              from: 600
              to: 0
          - refId: B
            datasourceUid: __expr__
            model:
              type: reduce
              expression: A
              reducer: last
          - refId: C
            datasourceUid: __expr__
            model:
              type: threshold
              expression: B
              conditions:
                - evaluator:
                    type: gt
                    params: [0.05]
        noDataState: OK
        execErrState: Error
        for: 2m
        labels:
          severity: critical
          service: otel-collector
          signal: metric
          component: observability
          timeframe: 10m
        annotations:
          expr: '(sum(rate(otelcol_processor_dropped_spans_total[5m])) / clamp_min(sum(rate(otelcol_receiver_accepted_spans_total[5m])), 1))'
          summary: "OTel Collector dropping >5% of spans"
          description: "The OTel Collector is dropping more than 5% of received spans."

      - uid: otel-collector-down
        title: OTelCollectorDown
        condition: C
        data:
          - refId: A
            datasourceUid: prometheus
            model:
              expr: 'up{{ "{" }}{{ otel_selector }}{{ "}" }}'
              instant: false
              range: true
              intervalMs: 15000
            relativeTimeRange:
              from: 300
              to: 0
          - refId: B
            datasourceUid: __expr__
            model:
              type: reduce
              expression: A
              reducer: last
          - refId: C
            datasourceUid: __expr__
            model:
              type: threshold
              expression: B
              conditions:
                - evaluator:
                    type: lt
                    params: [1]
        noDataState: OK
        execErrState: Error
        for: 1m
        labels:
          severity: critical
          service: otel-collector
          signal: metric
          component: observability
          timeframe: 5m
        annotations:
          expr: 'up{{ "{" }}{{ otel_selector }}{{ "}" }}'
          summary: "OTel Collector is down"
          description: "The OTel Collector instance has been unreachable for 1 minute."

  - orgId: 1
    name: infrastructure_alerts
    folder: Provisioned Alerts
    interval: 60s
    rules:
      - uid: high-disk-usage
        title: HighDiskUsage
        condition: C
        data:
          - refId: A
            datasourceUid: prometheus
            model:
              expr: '(1 - node_filesystem_avail_bytes{mountpoint="/",fstype!=""} / node_filesystem_size_bytes{mountpoint="/",fstype!=""}) * 100'
              instant: false
              range: true
              intervalMs: 15000
            relativeTimeRange:
              from: 600
              to: 0
          - refId: B
            datasourceUid: __expr__
            model:
              type: reduce
              expression: A
              reducer: last
          - refId: C
            datasourceUid: __expr__
            model:
              type: threshold
              expression: B
              conditions:
                - evaluator:
                    type: gt
                    params: [85]
        noDataState: OK
        execErrState: Error
        for: 5m
        labels:
          severity: warning
          service: k3s-node
          signal: metric
          component: infrastructure
          timeframe: 10m
        annotations:
          expr: '(1 - node_filesystem_avail_bytes{mountpoint="/",fstype!=""} / node_filesystem_size_bytes{mountpoint="/",fstype!=""}) * 100'
          summary: "Disk usage above 85%"
          description: "Root filesystem usage has exceeded 85% for 5 minutes."

      - uid: critical-disk-usage
        title: CriticalDiskUsage
        condition: C
        data:
          - refId: A
            datasourceUid: prometheus
            model:
              expr: '(1 - node_filesystem_avail_bytes{mountpoint="/",fstype!=""} / node_filesystem_size_bytes{mountpoint="/",fstype!=""}) * 100'
              instant: false
              range: true
              intervalMs: 15000
            relativeTimeRange:
              from: 600
              to: 0
          - refId: B
            datasourceUid: __expr__
            model:
              type: reduce
              expression: A
              reducer: last
          - refId: C
            datasourceUid: __expr__
            model:
              type: threshold
              expression: B
              conditions:
                - evaluator:
                    type: gt
                    params: [95]
        noDataState: OK
        execErrState: Error
        for: 2m
        labels:
          severity: critical
          service: k3s-node
          signal: metric
          component: infrastructure
          timeframe: 10m
        annotations:
          expr: '(1 - node_filesystem_avail_bytes{mountpoint="/",fstype!=""} / node_filesystem_size_bytes{mountpoint="/",fstype!=""}) * 100'
          summary: "Disk usage above 95%"
          description: "Root filesystem usage has exceeded 95%. Immediate action required."

      - uid: high-cpu-usage
        title: HighCpuUsage
        condition: C
        data:
          - refId: A
            datasourceUid: prometheus
            model:
              expr: '100 - (avg by(instance) (rate(node_cpu_seconds_total{mode="idle"}[5m])) * 100)'
              instant: false
              range: true
              intervalMs: 15000
            relativeTimeRange:
              from: 600
              to: 0
          - refId: B
            datasourceUid: __expr__
            model:
              type: reduce
              expression: A
              reducer: last
          - refId: C
            datasourceUid: __expr__
            model:
              type: threshold
              expression: B
              conditions:
                - evaluator:
                    type: gt
                    params: [85]
        noDataState: OK
        execErrState: Error
        for: 5m
        labels:
          severity: warning
          service: k3s-node
          signal: metric
          component: infrastructure
          timeframe: 10m
        annotations:
          expr: '100 - (avg by(instance) (rate(node_cpu_seconds_total{mode="idle"}[5m])) * 100)'
          summary: "High CPU usage"
          description: "CPU usage has been above 85% for 5 minutes."

      - uid: critical-cpu-usage
        title: CriticalCpuUsage
        condition: C
        data:
          - refId: A
            datasourceUid: prometheus
            model:
              expr: '100 - (avg by(instance) (rate(node_cpu_seconds_total{mode="idle"}[5m])) * 100)'
              instant: false
              range: true
              intervalMs: 15000
            relativeTimeRange:
              from: 600
              to: 0
          - refId: B
            datasourceUid: __expr__
            model:
              type: reduce
              expression: A
              reducer: last
          - refId: C
            datasourceUid: __expr__
            model:
              type: threshold
              expression: B
              conditions:
                - evaluator:
                    type: gt
                    params: [95]
        noDataState: OK
        execErrState: Error
        for: 2m
        labels:
          severity: critical
          service: k3s-node
          signal: metric
          component: infrastructure
          timeframe: 10m
        annotations:
          expr: '100 - (avg by(instance) (rate(node_cpu_seconds_total{mode="idle"}[5m])) * 100)'
          summary: "Critical CPU usage"
          description: "CPU usage has been above 95% for 2 minutes."

      - uid: high-memory-usage
        title: HighMemoryUsage
        condition: C
        data:
          - refId: A
            datasourceUid: prometheus
            model:
              expr: '(1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100'
              instant: false
              range: true
              intervalMs: 15000
            relativeTimeRange:
              from: 600
              to: 0
          - refId: B
            datasourceUid: __expr__
            model:
              type: reduce
              expression: A
              reducer: last
          - refId: C
            datasourceUid: __expr__
            model:
              type: threshold
              expression: B
              conditions:
                - evaluator:
                    type: gt
                    params: [85]
        noDataState: OK
        execErrState: Error
        for: 5m
        labels:
          severity: warning
          service: k3s-node
          signal: metric
          component: infrastructure
          timeframe: 10m
        annotations:
          expr: '(1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100'
          summary: "High memory usage"
          description: "Memory usage has exceeded 85% for 5 minutes."

      - uid: critical-memory-usage
        title: CriticalMemoryUsage
        condition: C
        data:
          - refId: A
            datasourceUid: prometheus
            model:
              expr: '(1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100'
              instant: false
              range: true
              intervalMs: 15000
            relativeTimeRange:
              from: 600
              to: 0
          - refId: B
            datasourceUid: __expr__
            model:
              type: reduce
              expression: A
              reducer: last
          - refId: C
            datasourceUid: __expr__
            model:
              type: threshold
              expression: B
              conditions:
                - evaluator:
                    type: gt
                    params: [95]
        noDataState: OK
        execErrState: Error
        for: 2m
        labels:
          severity: critical
          service: k3s-node
          signal: metric
          component: infrastructure
          timeframe: 10m
        annotations:
          expr: '(1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100'
          summary: "Critical memory usage"
          description: "Memory usage has exceeded 95%. OOM risk."

      # ADAPTIVE THRESHOLD — Epic 5 US-5.4 (2026-04-27).
      # CPU baseline is more seasonal than latency (3am idle vs 2pm peak),
      # so the same-hour-7-days-ago + 3σ pattern is most valuable here.
      # Static fallback floor: 80% (the prior MediumCpuUsage threshold).
      - uid: medium-cpu-usage
        title: MediumCpuUsage
        condition: C
        data:
          - refId: A
            datasourceUid: prometheus
            model:
              expr: |
                (100 - (avg by(instance) (rate(node_cpu_seconds_total{mode="idle"}[1m])) * 100))
                -
                (
                  avg_over_time((100 - (avg by(instance) (rate(node_cpu_seconds_total{mode="idle"}[1m])) * 100))[1h:1m] offset 7d)
                  + 3 * stddev_over_time((100 - (avg by(instance) (rate(node_cpu_seconds_total{mode="idle"}[1m])) * 100))[1h:1m] offset 7d)
                  or vector(80)
                )
              instant: false
              range: true
              intervalMs: 15000
            relativeTimeRange:
              from: 300
              to: 0
          - refId: B
            datasourceUid: __expr__
            model:
              type: reduce
              expression: A
              reducer: last
          - refId: C
            datasourceUid: __expr__
            model:
              type: threshold
              expression: B
              conditions:
                - evaluator:
                    type: gt
                    params: [0]
        noDataState: OK
        execErrState: Error
        for: 1m
        labels:
          severity: warning
          service: k3s-node
          signal: metric
          component: infrastructure
          timeframe: 5m
          adaptive_threshold: "true"
        annotations:
          expr: '100 - (avg by(instance) (rate(node_cpu_seconds_total{mode="idle"}[1m])) * 100)'
          summary: "CPU usage above adaptive baseline"
          description: "Per-instance CPU exceeds same-hour 7-day baseline by more than 3σ, or 80% if no baseline history is available. Adapts to traffic seasonality (3am vs 2pm baselines differ)."
          # US-5.8 recurrence-gate opt-in. Warning-severity rule with a known
          # noise profile — first 4 fires inside 2h are gated pre-LLM (no
          # email), and if the LLM dismisses the same fingerprint twice in
          # the window the next dismiss is force-flipped to ESCALATE so a
          # human can decide whether the rule is too noisy or there's a
          # real signal the LLM missed. CRITICAL-severity rules MUST NOT
          # carry this annotation. See decisions-log D21.
          recurrence_gate: "pre_llm=4,llm_dismiss=2,window=2h"

      - uid: medium-memory-usage
        title: MediumMemoryUsage
        condition: C
        data:
          - refId: A
            datasourceUid: prometheus
            model:
              expr: '(1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100'
              instant: false
              range: true
              intervalMs: 15000
            relativeTimeRange:
              from: 300
              to: 0
          - refId: B
            datasourceUid: __expr__
            model:
              type: reduce
              expression: A
              reducer: last
          - refId: C
            datasourceUid: __expr__
            model:
              type: threshold
              expression: B
              conditions:
