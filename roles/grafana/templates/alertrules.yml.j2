                    type: gt
                    params: [80]
        noDataState: OK
        execErrState: Error
        for: 1m
        labels:
          severity: warning
          service: k3s-node
          signal: metric
          component: infrastructure
          timeframe: 5m
        annotations:
          expr: '(1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100'
          summary: "Medium memory usage"
          description: "Memory usage is above 80% for 1 minute."
          # US-5.8 recurrence-gate opt-in (warning-severity, see D21).
          recurrence_gate: "pre_llm=4,llm_dismiss=2,window=2h"

      - uid: target-down
        title: TargetDown
        condition: C
        data:
          - refId: A
            datasourceUid: prometheus
            model:
              expr: 'up == 0'
              instant: false
              range: true
              intervalMs: 15000
            relativeTimeRange:
              from: 300
              to: 0
          - refId: B
            datasourceUid: __expr__
            model:
              type: reduce
              expression: A
              reducer: last
          - refId: C
            datasourceUid: __expr__
            model:
              type: threshold
              expression: B
              conditions:
                - evaluator:
                    type: lt
                    params: [1]
        noDataState: OK
        execErrState: Error
        for: 2m
        labels:
          severity: critical
          service: monitoring
          signal: metric
          component: scrape
          timeframe: 5m
        annotations:
          expr: 'up == 0'
          summary: "Monitored target is down"
          description: "A Prometheus scrape target has been unreachable for 2 minutes."

      - uid: disk-filling-up
        title: DiskFillingUp
        condition: C
        data:
          - refId: A
            datasourceUid: prometheus
            model:
              expr: 'predict_linear(node_filesystem_avail_bytes{mountpoint="/",fstype!=""}[6h], 24*3600)'
              instant: false
              range: true
              intervalMs: 15000
            relativeTimeRange:
              from: 21600
              to: 0
          - refId: B
            datasourceUid: __expr__
            model:
              type: reduce
              expression: A
              reducer: last
          - refId: C
            datasourceUid: __expr__
            model:
              type: threshold
              expression: B
              conditions:
                - evaluator:
                    type: lt
                    params: [0]
        noDataState: OK
        execErrState: Error
        for: 30m
        labels:
          severity: warning
          service: k3s-node
          signal: metric
          component: infrastructure
          timeframe: 6h
        annotations:
          expr: 'predict_linear(node_filesystem_avail_bytes{mountpoint="/",fstype!=""}[6h], 24*3600)'
          summary: "Disk predicted to fill within 24h"
          description: "Based on the last 6 hours of data, the root filesystem is predicted to run out of space within 24 hours."

