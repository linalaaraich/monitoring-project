apiVersion: 1

datasources:
  - name: Prometheus
    type: prometheus
    access: proxy
    url: http://prometheus:{{ prometheus_port }}
    isDefault: true
    uid: prometheus
    jsonData:
      timeInterval: "{{ prometheus_scrape_interval }}"

  - name: Loki
    type: loki
    access: proxy
    url: http://loki:{{ loki_port }}
    uid: loki
    jsonData:
      derivedFields:
        # matcherType "regex" runs the pattern against the log body (not the
        # stream label, which is what "label" does). Spring Boot's log pattern
        # is customized via LOGGING_PATTERN_LEVEL to include "trace_id=<hex>"
        # in every line via the OTel Java Agent's logback-mdc instrumentation.
        - matcherType: regex
          matcherRegex: 'trace_id=([0-9a-f]{32})'
          name: TraceID
          # IMPORTANT: This URL is rendered into the USER'S BROWSER when they
          # click a trace_id in a log line — so it must be an address the
          # operator's browser can reach, NOT a private/in-VPC IP.
          # Uses monitoring_vm_public_ip (group_vars/all.yml) which is set to
          # the monitoring VM's Elastic IP on AWS deployments.
          url: 'http://{{ monitoring_vm_public_ip | default(monitoring_vm_ip) }}:{{ jaeger_port_ui }}/trace/$${__value.raw}'
          urlDisplayLabel: View in Jaeger
          openInNewTab: true

  - name: Jaeger
    type: jaeger
    access: proxy
    url: http://jaeger:{{ jaeger_port_ui }}
    uid: jaeger
    jsonData:
      tracesToMetrics:
        datasourceUid: prometheus
        spanStartTimeShift: "-1h"
        spanEndTimeShift: "1h"
        tags:
          - key: service.name
            value: service
      tracesToLogs:
        datasourceUid: loki
        spanStartTimeShift: "-1h"
        spanEndTimeShift: "1h"
        filterByTraceID: false
        filterBySpanID: false
        customQuery: true
        query: '{service_name="${__span.tags["service.name"]}"} |= "${__span.traceId}"'
        tags:
          - key: service.name
            value: service
      nodeGraph:
        enabled: true
