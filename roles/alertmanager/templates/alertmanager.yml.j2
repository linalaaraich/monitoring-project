global:
  smtp_smarthost: '{{ alertmanager_smtp_smarthost }}'
  smtp_from: '{{ alertmanager_smtp_from }}'
  smtp_auth_username: '{{ alertmanager_smtp_username }}'
  smtp_auth_password: '{{ alertmanager_smtp_password }}'
  smtp_require_tls: true

route:
  receiver: 'email-default'
  group_by: ['alertname', 'severity']
  group_wait: 30s
  group_interval: 5m
  repeat_interval: 4h
  routes:
    - receiver: 'email-critical'
      match:
        severity: critical
      repeat_interval: 1h

receivers:
  - name: 'email-default'
    email_configs:
      - to: '{{ alertmanager_receiver_email }}'
        send_resolved: true
        headers:
          Subject: '{% raw %}[{{ .Status | toUpper }}] {{ .GroupLabels.alertname }}{% endraw %}'

  - name: 'email-critical'
    email_configs:
      - to: '{{ alertmanager_receiver_email }}'
        send_resolved: true
        headers:
          Subject: '{% raw %}[CRITICAL] {{ .GroupLabels.alertname }}{% endraw %}'

inhibit_rules:
  - source_match:
      severity: 'critical'
    target_match:
      severity: 'warning'
    equal: ['alertname']
