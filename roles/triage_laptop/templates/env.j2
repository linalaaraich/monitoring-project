# =============================================================================
# CIRES AI triage .env file — MANAGED BY ANSIBLE
#
# This file is templated by roles/triage_laptop/templates/env.j2 and written
# to {{ laptop_compose_dir }}/.env on every ansible-playbook run.
#
# DO NOT EDIT BY HAND — changes here are overwritten on the next run.
# To change values, update inventory/group_vars/laptop_workstations.yml
# (or roles/triage_laptop/defaults/main.yml) and re-run the playbook:
#
#     ansible-playbook -i inventory/tailnet.yml playbooks/laptop.yml
#
# Last templated: {{ ansible_date_time.iso8601 }}
# =============================================================================

# Image tags — Watchtower auto-pulls newer ghcr.io/linalaaraich/*:main between
# runs, but this is the tag ansible requests on this specific deploy.
TRIAGE_TAG={{ triage_image_tag }}
IMAGE_TAG={{ mcp_image_tag }}

# Ollama model loaded by ai-ollama-init on boot
OLLAMA_MODEL={{ laptop_ollama_model }}

# Monitoring-VM (Grafana + Prometheus + Loki + Jaeger) — Tailscale IP
MONITORING_VM_IP={{ monitoring_vm_ip }}

# =============================================================================
# Triage service tunables (override defaults in app/config.py)
# =============================================================================

# Grafana — used for email deep-links + P0.5 startup backfill + P1.5 bounded
# agency's rca_history tool (it hits /api/v1/rules/history via this URL).
GRAFANA_URL={{ laptop_grafana_url }}
GRAFANA_API_USER={{ laptop_grafana_api_user }}
GRAFANA_API_PASSWORD={{ laptop_grafana_api_password }}

# Context gathering bundle size. Bigger = more evidence for the LLM but more
# tokens + slower inference. Current defaults match the post-2026-04-23 bump.
PROMETHEUS_RANGE_MINUTES={{ laptop_prometheus_range_minutes }}
LOKI_LOG_LIMIT={{ laptop_loki_log_limit }}
JAEGER_TRACE_LIMIT={{ laptop_jaeger_trace_limit }}
CONTEXT_TIMEOUT={{ laptop_context_timeout }}

# Dedup + Layer-2 suppression
DEDUP_WINDOW_SECONDS={{ laptop_dedup_window_seconds }}
TRIAGE_SUPPRESSION_ENABLED={{ laptop_triage_suppression_enabled | string | lower }}
TRIAGE_HISTORY_LOOKBACK_MINUTES={{ laptop_triage_history_lookback_minutes }}

# Data-starved retry + bounded agency (P1.5)
TRIAGE_DATA_STARVED_RETRY_ENABLED={{ laptop_triage_data_starved_retry_enabled | string | lower }}
TRIAGE_BOUNDED_AGENCY_ENABLED={{ laptop_triage_bounded_agency_enabled | string | lower }}

# Drain3 self-alerting (P1.7) — when anomaly rate crosses threshold in a
# sliding window, /webhook/drain3 fires so drain3 becomes a visible
# alert source on the dashboard.
DRAIN3_ALERT_ENABLED={{ laptop_drain3_alert_enabled | string | lower }}
DRAIN3_ALERT_RATE_THRESHOLD={{ laptop_drain3_alert_rate_threshold }}
DRAIN3_ALERT_MIN_LINES={{ laptop_drain3_alert_min_lines }}
DRAIN3_ALERT_COOLDOWN_SECONDS={{ laptop_drain3_alert_cooldown_seconds }}

# Ollama resilience
OLLAMA_REQUEST_TIMEOUT={{ laptop_ollama_request_timeout }}
PIPELINE_TIMEOUT={{ laptop_pipeline_timeout }}
CIRCUIT_BREAKER_FAILURE_THRESHOLD={{ laptop_circuit_breaker_failure_threshold }}
CIRCUIT_BREAKER_COOLDOWN_SECONDS={{ laptop_circuit_breaker_cooldown_seconds }}

# Startup backfill — only active when GRAFANA_API_PASSWORD is set (above).
STARTUP_BACKFILL_THRESHOLD_MINUTES={{ laptop_startup_backfill_threshold_minutes }}
STARTUP_BACKFILL_MAX_GAP_HOURS={{ laptop_startup_backfill_max_gap_hours }}

# =============================================================================
# SMTP — for escalation emails
# =============================================================================
SMTP_HOST={{ laptop_smtp_host }}
SMTP_PORT={{ laptop_smtp_port }}
SMTP_USER={{ laptop_smtp_user }}
SMTP_PASSWORD={{ laptop_smtp_password }}
SMTP_FROM={{ laptop_smtp_from }}
NOTIFICATION_EMAIL={{ laptop_notification_email }}
